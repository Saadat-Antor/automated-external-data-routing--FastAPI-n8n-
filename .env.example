# --- DATABASE SETTINGS ---
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=your_postgres_name
DB_HOST = your_db_host
DB_PORT = your_db_port
DB_NAME = your_db_name

# --- n8n SETTINGS ---
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=your_n8n_user
N8N_BASIC_AUTH_PASSWORD=your_n8n_pass
GENERIC_TIMEZONE=your_n8n_timezone
TZ=your_n8n_timezone

# --- NETWORK SETTINGS ---
# Update this whenever your Localtunnel URL changes
WEBHOOK_URL=your_n8n_webhook_url
# --- SECURITY ---
# This must match the token in your FastAPI main.py
SECRET_KEY=your_backend_secret_key

# --- Gemini API Key ---
GEMINI_API_KEY=your_gemini_api_key
